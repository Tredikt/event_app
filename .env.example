# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=communicate_db
POSTGRES_PORT=5432

# Used by local dev (uvicorn without Docker)
DATABASE_URL=postgresql+asyncpg://postgres:change-me@localhost:5432/communicate_db

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# Used by local dev
REDIS_URL=redis://localhost:6379/0

# ── App ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-64-char-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ── Ports ───────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=80

# ── URLs ────────────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# ── Telegram ────────────────────────────────────────────────────────────────
# Get token from @BotFather, then set webhook:
# POST https://api.telegram.org/bot{TOKEN}/setWebhook?url=https://your-domain.com/telegram/webhook
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram IDs of admins (get your ID via /myid command in bot)
ADMIN_TELEGRAM_IDS=

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ── Uploads ──────────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_AVATAR_SIZE_MB=5

# ── S3 Object Storage (optional — falls back to local uploads/ if not set) ───
# Yandex Object Storage example:
#   S3_ENDPOINT_URL=https://storage.yandexcloud.net
#   S3_PUBLIC_URL=https://<bucket>.storage.yandexcloud.net
# AWS S3 example:
#   S3_ENDPOINT_URL=   (leave empty for AWS default)
#   S3_PUBLIC_URL=https://<bucket>.s3.<region>.amazonaws.com
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_REGION=ru-central1
S3_PUBLIC_URL=

# ── Frontend build ───────────────────────────────────────────────────────────
# Yandex Maps JS API key — create at https://developer.tech.yandex.ru/
# Required permissions: JavaScript API
VITE_YANDEX_MAPS_API_KEY=
